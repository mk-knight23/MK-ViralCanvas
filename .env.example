# MK ViralCanvas — Environment Variables
# Copy this file to .env.local for local dev, or set these in the Vercel project.
# All variables are optional. The app works without any of them set.

# --- Analytics (optional, per docs/ANALYTICS.md) ---
# VITE_ prefix = client-visible at build time.
VITE_GTM_ID=
VITE_GA4_ID=

# --- Search providers (server-only, never exposed to client) ---
# Each provider activates its /api/memes/search source when set.
# Without any of these, /api/memes/templates still serves Imgflip results.
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
SEARCHAPI_API_KEY=
EXA_API_KEY=
SCRAPINGDOG_API_KEY=
APIFY_API_KEY=

# --- AI (not wired yet; placeholders for future work) ---
# AI_PROVIDER=openai|anthropic|google
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
